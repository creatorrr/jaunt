#!/usr/bin/env python3
"""Makeshift `codex` CLI that fronts the Claude Code CLI.

Speaks just enough of the `codex exec --json -` surface for Jaunt's
CodexBackend: prompt on stdin, JSONL events on stdout (item.completed with an
agent_message, then turn.completed with usage). Flags that have no Claude
equivalent (-m model, --sandbox, -c config overrides, --ignore-user-config)
are accepted and ignored; -C sets the working directory Claude runs in, with
edit permissions scoped to it.
"""

import json
import subprocess
import sys

_VALUE_FLAGS = {"-C", "-m", "--sandbox", "-c"}


def main() -> int:
    args = sys.argv[1:]
    if not args or args[0] != "exec":
        sys.stderr.write("makeshift codex: only `codex exec` is supported\n")
        return 2

    cwd = None
    i = 1
    while i < len(args):
        arg = args[i]
        if arg in _VALUE_FLAGS:
            if arg == "-C" and i + 1 < len(args):
                cwd = args[i + 1]
            i += 2
            continue
        i += 1

    prompt = sys.stdin.read()
    cmd = [
        "claude",
        "-p",
        "--output-format",
        "json",
        "--permission-mode",
        "acceptEdits",
    ]
    if cwd:
        cmd += ["--add-dir", cwd]

    proc = subprocess.run(cmd, input=prompt, capture_output=True, text=True, cwd=cwd)
    if proc.returncode != 0:
        detail = (proc.stderr or proc.stdout).strip()[:2000]
        print(json.dumps({"type": "error", "message": f"claude -p failed: {detail}"}))
        return 1

    try:
        data = json.loads(proc.stdout)
    except ValueError:
        print(json.dumps({"type": "error", "message": "claude -p emitted non-JSON output"}))
        return 1

    usage = data.get("usage") or {}
    print(
        json.dumps(
            {
                "type": "item.completed",
                "item": {"type": "agent_message", "text": data.get("result", "")},
            }
        )
    )
    print(
        json.dumps(
            {
                "type": "turn.completed",
                "usage": {
                    "input_tokens": usage.get("input_tokens", 0),
                    "output_tokens": usage.get("output_tokens", 0),
                    "cached_input_tokens": usage.get("cache_read_input_tokens", 0),
                },
            }
        )
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
