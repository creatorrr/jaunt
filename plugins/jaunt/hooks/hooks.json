{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/scripts/codex-guard.sh\"",
            "timeout": 10,
            "statusMessage": "Checking Jaunt-owned files"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${PLUGIN_ROOT}/scripts/session-status.sh\"",
            "timeout": 120,
            "statusMessage": "Checking Jaunt workspace freshness"
          }
        ]
      }
    ]
  }
}
