{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2023",
    "lib": ["ES2023"],
    "types": ["node"],
    "strict": true,
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmitOnError": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/**/*.jaunt.ts",
    "src/**/*.jaunt.tsx",
    "src/**/*.jaunt-test.ts",
    "src/**/*.jaunt-test.tsx",
    "dist",
    "node_modules"
  ]
}
