{
  "name": "jaunt-ts-preview",
  "private": true,
  "version": "0.0.0",
  "description": "Runnable architecture and packed-consumer fixture for Jaunt TypeScript",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/tokens",
    "README.md"
  ],
  "exports": {
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    }
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.test.json && tsc -p tsconfig.analysis.json",
    "test": "vitest run",
    "emit": "tsc -p tsconfig.json",
    "demo": "npm run --silent emit && node dist/app.js",
    "smoke:consumer": "npm run --silent emit && node consumer-smoke.mjs"
  },
  "devDependencies": {
    "@usejaunt/ts": "file:../../packages/jaunt-ts",
    "@types/node": "^22.10.0",
    "fast-check": "^4.1.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
