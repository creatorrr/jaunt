{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["node", "vitest/globals"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"],
  "exclude": ["**/*.jaunt.ts", "**/*.jaunt.tsx", "**/*.jaunt-test.ts", "**/*.jaunt-test.tsx"]
}
